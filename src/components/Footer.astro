---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div>
			<a class="footer-brand" href="/">Onurce İnşaat</a>
			<p>Planlı, şeffaf ve dayanıklı yapılar için uçtan uca inşaat yönetimi.</p>
		</div>
		<div class="footer-links" aria-label="Alt menü">
			<a href="#hakkimizda">Hakkımızda</a>
			<a href="#projeler">Projeler</a>
			<a href="#iletisim">İletişim</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} Onurce İnşaat. Tüm hakları saklıdır.</p>
	</div>
</footer>

<style>
	footer {
		background: var(--klasik-dark);
		color: rgba(253, 253, 254, 0.72);
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 28px;
		width: min(1180px, calc(100% - 40px));
		margin: 0 auto;
		padding: 42px 0;
	}

	.footer-brand {
		color: var(--klasik-white);
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
	}

	p {
		max-width: 420px;
		margin: 8px 0 0;
	}

	.footer-links {
		display: flex;
		gap: 20px;
		font-size: 0.82rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.footer-links a {
		color: var(--klasik-white);
		text-decoration: none;
	}

	.footer-links a:hover {
		color: var(--klasik-accent);
	}

	.copyright {
		margin: 0;
		font-size: 0.9rem;
	}

	@media (max-width: 767px) {
		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
			width: min(100% - 28px, 1180px);
		}
	}
</style>
