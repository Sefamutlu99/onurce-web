---
import { SITE_TITLE } from "../consts";
---

<header>
	<nav>
		<a class="brand" href="/" aria-label="Onurce İnşaat ana sayfa">
			<span class="brand-mark" aria-hidden="true">OI</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<a href="#hakkimizda">Hakkımızda</a>
			<a href="#model">Model</a>
			<a href="#projeler">Projeler</a>
			<a href="#iletisim">İletişim</a>
		</div>
		<a class="nav-cta" href="#iletisim">Teklif Al</a>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(19, 14, 11, 0.1);
		background: rgba(253, 253, 254, 0.94);
		backdrop-filter: blur(14px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		width: min(1180px, calc(100% - 40px));
		min-height: 78px;
		margin: 0 auto;
	}

	.brand,
	.nav-links,
	.nav-cta {
		display: flex;
		align-items: center;
	}

	.brand {
		gap: 12px;
		color: var(--klasik-dark);
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 42px;
		height: 42px;
		background: var(--klasik-dark);
		color: var(--klasik-white);
		font-size: 0.72rem;
	}

	.nav-links {
		gap: 26px;
		font-size: 0.82rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.nav-links a {
		color: var(--klasik-dark);
		text-decoration: none;
	}

	.nav-links a:hover {
		color: var(--klasik-accent);
	}

	.nav-cta {
		justify-content: center;
		min-height: 44px;
		padding: 0 18px;
		background: var(--klasik-accent);
		color: var(--klasik-white);
		font-size: 0.78rem;
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
	}

	.nav-cta:hover {
		background: var(--klasik-dark);
		color: var(--klasik-white);
	}

	@media (max-width: 767px) {
		nav {
			width: min(100% - 28px, 1180px);
			min-height: 68px;
		}

		.nav-links {
			display: none;
		}
	}

	@media (max-width: 479px) {
		.brand span:last-child {
			max-width: 118px;
			line-height: 1.05;
		}

		.nav-cta {
			padding: 0 12px;
		}
	}
</style>
